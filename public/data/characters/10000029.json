eory":"2U","internalCooldown":null,"interruptionResistance":"120","interruptionResistanceStagger":{"staggerLevel":"Air","horizontalForce":"480","verticalForce":"600"},"bluntAttack":false}]},"4":{"skillId":2921,"type":2,"name":"砰砰礼物","description":"<color=#FFD780FF>蹦蹦炸弹</color>与普通攻击造成伤害时，有50%的几率赋予可莉一朵爆裂火花。\\n施放重击时将消耗爆裂火花，使本次重击不消耗体力，造成的伤害提升50%。","descriptionBuff":"元素战技<color=#FFD780FF>蹦蹦炸弹</color>与普通攻击造成伤害时，有50%的几率赋予可莉一朵爆裂火花；施放元素战技<color=#FFD780FF>蹦蹦炸弹</color>与元素爆发<color=#FFD780FF>轰轰火花</color>时，也会赋予可莉一朵爆裂火花。可莉至多持有三朵爆裂火花。\\n可莉持有爆裂火花并进行重击时，将消耗一朵爆裂火花，转而施放特殊的、不消耗体力的重击「嘭嘭轰击」，并使其造成的伤害提升50%。\\n\\n<color=#FFD780FF>魔导·秘仪</color>\\n元素爆发<color=#FFD780FF>轰轰火花</color>的技能持续时间内，可莉的普通攻击连击段数不会重置；可莉持有爆裂火花并进行普通攻击时，第三段攻击将会消耗一朵爆裂火花，对敌人追加一次等同于「嘭嘭轰击」的攻击。","icon":"UI_Talent_S_Klee_05","linkedConstellations":null},"5":{"skillId":2922,"type":2,"name":"火花无限","description":"可莉的重击造成暴击后，为队伍中所有角色恢复2点元素能量。","descriptionBuff":"","icon":"UI_Talent_S_Klee_06","linkedConstellations":null},"6":{"skillId":2923,"type":2,"name":"全是宝藏","description":"在小地图上显示周围的<color=#FFD780FF>蒙德区域特产</color>的位置。","descriptionBuff":"","icon":"UI_Talent_Collect_Local_Mengde","linkedConstellations":null},"9":{"skillId":2951,"type":2,"name":"魔女的前夜礼·火花魔法","description":"完成<color=#FFD780FF>魔女的课业·火花叶之题</color>后，可莉将成为<color=#FFD780FF>魔导</color>角色。队伍中编入至少2名魔导角色时，将获得<color=#FFD780FF>魔导·秘仪</color>效果，使魔导角色获得强化。\\n\\n<color=#FFD780FF>魔导·秘仪</color>\\n可莉的普通攻击、元素战技或元素爆发造成伤害时，会获得一枚「轰轰勋章」，持续20秒，每种类别的攻击至多通过这种方式使可莉获得一枚「轰轰勋章」，通过不同类别的攻击获得的「轰轰勋章」独立存在。当可莉拥有1/2/3枚「轰轰勋章」时，特殊重击「嘭嘭轰击」将会造成原本115%/130%/150%的伤害。","descriptionBuff":"","icon":"UI_Talent_S_Klee_07","linkedConstellations":null}},"constellation":{"0":{"id":0,"talentId":291,"name":"连环轰隆","description":"攻击与施放技能时，有几率召唤火花轰击敌人，造成相当于<color=#FFD780FF>轰轰火花</color>攻击伤害120%的伤害。","descriptionBuff":"攻击与施放技能时，有几率召唤火花轰击敌人，造成相当于<color=#FFD780FF>轰轰火花</color>攻击伤害120%的伤害。\\n触发上述效果后的12秒内，可莉的攻击力提升60%。","extraData":null,"icon":"UI_Talent_S_Klee_01","advancedProps":[{"name":"Extra Spark","elementalGaugeTheory":"1U",