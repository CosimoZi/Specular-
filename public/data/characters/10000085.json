Stagger":{"staggerLevel":"Heavy","horizontalForce":"200","verticalForce":"0"},"bluntAttack":true},{"name":"Normal Attack 4-Hit","elementalGaugeTheory":"1U","internalCooldown":"rowspan","interruptionResistance":"165.5529","interruptionResistanceStagger":{"staggerLevel":"Air","horizontalForce":"480","verticalForce":"600"},"bluntAttack":true},{"name":"Charged Attack Cyclic","elementalGaugeTheory":"1U","internalCooldown":"rowspan","interruptionResistance":"60","interruptionResistanceStagger":{"staggerLevel":"Heavy","horizontalForce":"200","verticalForce":"0"},"bluntAttack":true},{"name":"Charged Attack Final Slash","elementalGaugeTheory":"1U","internalCooldown":"rowspan","interruptionResistance":"120","interruptionResistanceStagger":{"staggerLevel":"Air","horizontalForce":"480","verticalForce":"600"},"bluntAttack":true},{"name":"Plunging Attack Collision","elementalGaugeTheory":"0U","internalCooldown":null,"interruptionResistance":"35","interruptionResistanceStagger":{"staggerLevel":"Light","horizontalForce":"200","verticalForce":"0"},"bluntAttack":false},{"name":"Low Plunge","elementalGaugeTheory":"1U","internalCooldown":null,"interruptionResistance":"150","interruptionResistanceStagger":{"staggerLevel":"Heavy","horizontalForce":"800","verticalForce":"0"},"bluntAttack":true},{"name":"High Plunge","elementalGaugeTheory":"1U","internalCooldown":null,"interruptionResistance":"200","interruptionResistanceStagger":{"staggerLevel":"Air","horizontalForce":"0","verticalForce":"800"},"bluntAttack":true}]},"1":{"skillId":10852,"type":0,"name":"浮冰增压","description":"进行上挑攻击，造成<color=#99FFFFFF>冰元素伤害</color>，并进入持续10秒的佩伊刻计状态。\\n处于佩伊刻计状态下时，元素战技将转为高压粉碎。\\n\\n<color=#FFD780FF>高压粉碎</color>\\n依据佩伊刻计的压力阶级进行不同的攻击，并移除佩伊刻计状态：\\n·零阶时：进行纵斩，造成<color=#99FFFFFF>冰元素伤害</color>；\\n·一阶至三阶时：进行纵斩并协同佩伊，造成<color=#99FFFFFF>冰元素伤害</color>与物理伤害。伤害依据压力阶级有所不同；\\n·四阶时：借助充满压力的佩伊的力量，造成物理伤害。此时「普通攻击·洑流剑」将被替换为高压粉碎。\\n\\n<color=#FFD780FF>佩伊刻计</color>\\n菲米尼进行普通攻击时，将同时释放霜寒造成<color=#99FFFFFF>冰元素伤害</color>，并为佩伊刻计提升压力阶级。\\n同时造成的<color=#99FFFFFF>冰元素伤害</color>视为元素战技伤害。\\n\\n<color=#FFD780FF>始基力：芒性</color>\\n每隔一段时间，进行上挑攻击后，将形成进行挑击的灵息之刺，造成具有芒性的<color=#99FFFFFF>冰元素伤害</color>。\\n\\n<i>阻滞对手的行动，而非夺去对手的性命。从某种意义上来说，这也是为了「生存」而选择的战略。</i>\\n<i>「佩伊…接下来就拜托你了。」</i>","descriptionBuff":null,"icon":"Skill_S_Freminet_01","promote":{"1":{"level":1,"costItems":null,"coinCost":null,"description":["上挑攻击伤害|{param1:F1P}","霜寒伤害|{param3:F1P}","零阶高压粉碎伤害|{param4:F1P}","一阶高压粉碎伤害|{param5:F1P}冰元素+{param6:F1P}物理","二阶高压粉碎伤害|{param7:F1P}冰元素+{param8:F1P}物理","三阶高压粉碎伤害|{param9:F1P}冰元素+{param10:F1P}物理","四阶高压粉碎伤害|{param11:F1P}","灵息之刺伤害|{param2:F1P}","灵息之刺间隔|{param13:F1}秒","冷却时间|{param12:F1}秒","","","","","",""],"params":[0.8304,0.144,0.0716,2.0048,1.0024,0.48688,0.70168,0.85204,0.40096,1.2172,2.4344,10,9,0,0,0,0,0,0,0]},"2":{"level":2,"costItems":{"104341":3,"112080":6},"coinCost":12500,"description":["上挑攻击伤害|{param1:F1P}","霜寒伤害|{param3:F1P}","零阶高压粉碎伤害|{param4:F1P}","一阶高压粉碎伤害|{param5:F1P}冰元素+{param6:F1P}物理","二阶高压粉碎伤害|{param7:F1P}冰元素+{param8:F1P}物理","三阶高压粉碎伤害|{param9:F1P}冰元素+{param10:F1P}物理","四阶高压粉碎伤害|{param11:F1P}","灵息之刺伤害|{param2:F1P}","灵息之刺间隔|{param13:F1}秒","冷却时间|{param12:F1}秒","","","","","",""],"params":[0.89268,0.1548,0.07697,2.15516,1.07758,0.523396,0.754306,0.915943,0.431032,1.30849,2.61698,10,9,0,0,0,0,0,0,0]},"3":{"level":3,"costItems":{"104342":2,"112081":3},"coinCost":17500,"description":["上挑攻击伤害|{param1:F1P}","霜寒伤害|{param3:F1P}","零阶高压粉碎伤害|{param4:F1P}","一阶高压粉碎伤害|{param5:F1P}冰元素+{param6:F1P}物理","二阶高压粉碎伤害|{param7:F1P}冰元素+{param8:F1P}物理","三阶高压粉碎伤害|{param9:F1P}冰元素+{param10:F1P}物理","四阶高压粉碎伤害|{param11:F1P}","灵息之刺伤害|{param2:F1P}","灵息之刺间隔|{param13:F1}秒","冷却时间|{param12:F1}秒","","","","","",""],"params":[0.95496,0.1656,0.08234,2.30552,1.15276,0.559912,0.806932,0.979846,0.461104,1.39978,2.79956,10,9,0,0,0,0,0,0,0]},"4":{"level":4,"costItems":{"104342":4,"112081":4},"coinCost":25000,"description":["上挑攻击伤害|{param1:F1P}","霜寒伤害|{param3:F1P}","零阶高压粉碎伤害|{param4:F1P}","一阶高压粉碎伤害|{param5:F1P}冰元素+{param6:F1P}物理","二阶高压粉碎伤害|{param7:F1P