4":45,"104143":6,"112103":12,"113072":12},"unlockMaxLevel":80,"requiredPlayerLevel":40,"addProps":{"FIGHT_PROP_BASE_HP":3457.434,"FIGHT_PROP_BASE_DEFENSE":212.80725,"FIGHT_PROP_BASE_ATTACK":97.022095,"FIGHT_PROP_CRITICAL":0.144},"coinCost":100000},{"promoteLevel":6,"promoteAudio":"","costItems":{"101254":60,"104144":6,"112103":24,"113072":20},"unlockMaxLevel":90,"requiredPlayerLevel":50,"addProps":{"FIGHT_PROP_BASE_HP":4059.6965,"FIGHT_PROP_BASE_DEFENSE":249.8769,"FIGHT_PROP_BASE_ATTACK":113.922714,"FIGHT_PROP_CRITICAL":0.192},"coinCost":120000}]},"other":{"costume":[{"name":"糖分欢意","description":"瓦雷莎的装扮款式。对瓦雷莎来说，美好的糖分是上天赐予的礼物，亮粉色、翠青色的蛋糕、果茶还有糖果，全都是世界第一快乐来源！遗憾的是，教练并不这么认为。","isDefault":true}],"furnitureId":368197,"nameCard":{"id":210236,"name":"瓦雷莎·力源","description":"名片纹饰。\\n支撑她身躯里如此之大力量的能量来源是什么呢？也许是一个比整个世界都略大的胃口…吧？","icon":"UI_NameCardIcon_Varesa"},"specialFood":{"id":108810,"name":"菇菇山脉（单人份）","rank":2,"effectIcon":"UI_Buff_Item_Atk_CritRate","icon":"UI_ItemIcon_108800"}},"ascension":{"101254":1,"104141":2,"104142":3,"104143":4,"104144":5,"104319":5,"104353":2,"104354":3,"104355":4,"112101":1,"112102":2,"112103":3,"113070":5,"113072":4},"items":{"202":{"name":"摩拉","rank":3,"icon":"UI_ItemIcon_202"},"101254":{"name":"云岩裂叶","rank":1,"icon":"UI_ItemIcon_101254"},"104001":{"name":"流浪者的经验","rank":2,"icon":"UI_ItemIcon_104001"},"104002":{"name":"冒险家的经验","rank":3,"icon":"UI_ItemIcon_104002"},"104003":{"name":"大英雄的经验","rank":4,"icon":"UI_ItemIcon_104003"},"104141":{"name":"最胜紫晶碎屑","rank":2,"icon":"UI_ItemIcon_104141"},"104142":{"name":"最胜紫晶断片","rank":3,"icon":"UI_ItemIcon_104142"},"104143":{"name":"最胜紫晶块","rank":4,"icon":"UI_ItemIcon_104143"},"104144":{"name":"最胜紫晶","rank":5,"icon":"UI_ItemIcon_104144"},"104319":{"name":"智识之冕","rank":5,"icon":"UI_ItemIcon_104319"},"104353":{"name":"「纷争」的教导","rank":2,"icon":"UI_ItemIcon_104353"},"104354":{"name":"「纷争」的指引","rank":3,"icon":"UI_ItemIcon_104354"},"104355":{"name":"「纷争」的哲学","rank":4,"icon":"UI_ItemIcon_104355"},"112101":{"name":"稚嫩的尖齿","rank":1,"icon":"UI_ItemIcon_112101"},"112102":{"name":"老练的坚齿","rank":2,"icon":"UI_ItemIcon_112102"},"112103":{"name":"横行霸者的利齿","rank":3,"icon":"UI_ItemIcon_112103"},"113070":{"name":"蚀灭的鳞羽","rank":5,"icon":"UI_ItemIcon_113070"},"113072":{"name":"龙像的无智核","rank":4,"icon":"UI_ItemIcon_113072"}},"talent":{"0":{"skillId":11111,"type":0,"name":"角力搏摔","description":"<color=#FFD780FF>普通攻击</color>\\n要…要努力像厉害的摔角冠军那样战斗！进行至多三段的搏击，造成<color=#FFACFFFF>雷元素伤害</color>。\\n\\n<color=#FFD780FF>重击</color>\\n消耗一定体力，以头槌向前撞击敌人，造成具有夜魂性质的<color=#FFACFFFF>雷元素伤害</color>，并借势腾跃而起。\\n\\n<color=#FFD780FF>下落攻击</color>\\n从空中下坠冲击地面，攻击下落路径上的敌人，并在落地时造成具有夜魂性质的<color=#FFACFFFF>雷元素范围伤害</color>；若此时瓦雷莎处于战斗状态，或本次坠地冲击命中了敌人，则瓦雷莎获得25点夜魂值；通过这种方式使夜魂值达到上限时，瓦雷莎将进入「炽热激情」状态。\\n\\n<color=#FFD780FF>炽热激情</color>\\n在这种状态下，瓦雷莎的普通攻击、重击和下落攻击将得到对应的强化：\\n\\n<color=#FFD780FF>普通攻击</color>\\n如同明星摔角冠军那样无畏战斗！进行至多三段的猛烈搏击，造成伤害更高的<color=#FFACFFFF>雷元素伤害</color>。\\n\\n<color=#FFD780FF>重击</color>\\n消耗一定体力，猛烈前冲撞击敌人，造成伤害更高的、具有夜魂性质的<color=#FFACFFFF>雷元素伤害</color>，并借势腾跃而起。\\n\\n<color=#FFD780FF>下落攻击</color>\\n消耗全部夜魂值，从空中下坠冲击地面，攻击下落路径上的敌人，并在落地时造成伤害更高的、具有夜魂性质的<color=#FFACFFFF>雷元素范围伤害</color>。","descriptionBuff":null,"icon":"Skill_A_Catalyst_MD","promote":{"1":{"level":1,"costItems":null,"coinCost":null,"description":["一段伤害|{param1:F1P}","二段伤害|{param2:F1P}","三段伤害|{param3:F1P}","重击伤害|{param4:F1P}","重击体力消耗|{param5:F1}点","下坠期间伤害|{param6:F1P}","低空/高空坠地冲击伤害|{param7:P}/{param8:P}","炽热激情状态一段伤害|{param9:F1P}","炽热激情状态二段伤害|{param10:F1P}","炽热激情状态三段伤害|{param11:F1P}","炽热激情状态重击伤害|{param12:F1P}","炽热激情状态重击体力消耗|{param13:F1}点","炽热激情状态下坠期间伤害|{param14:F1P}","炽热激情状态低空/高空坠地冲击伤害|{param15:P}/{param16:P}","",""],"params":[0.467784,0.40028,0.563128,0.8928,50,0.745878,1.49144,1.862889,0.544072,0.520288,0.735864,0.9264,50,0.745878,2.23716,2.794334,0,0,0,0]},"2":{"level":2,"costItems":{"104353":3,"112101":6},"coinCost":12500,"description":["一段伤害|{param1:F1P}","二段伤害|{param2:F1P}","三段伤害|{param3:F1P}","重击伤害|{param4:F1P}","重击体力消耗|{param5:F1}点","下坠期间伤害|{param6:F1P}","低空/高空坠