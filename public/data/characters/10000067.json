:null,"extraData":null,"icon":"UI_Talent_S_Collei_02"},"2":{"id":2,"talentId":673,"name":"夏堇芳菲","description":"<color=#FFD780FF>拂花偈叶</color>的技能等级提高3级。\\n至多提升至15级。","descriptionBuff":null,"extraData":{"addTalentExtraLevel":{"talentType":"AvatarSkill","talentIndex":2,"extraLevel":3}},"icon":"UI_Talent_U_Collei_02"},"3":{"id":3,"talentId":674,"name":"骞林馈遗","description":"施放<color=#FFD780FF>猫猫秘宝</color>时，将使队伍中附近的所有角色（不包括柯莱自己）的元素精通提升60点，持续12秒。","descriptionBuff":null,"extraData":null,"icon":"UI_Talent_S_Collei_03"},"4":{"id":4,"talentId":675,"name":"俱象残火","description":"<color=#FFD780FF>猫猫秘宝</color>的技能等级提高3级。\\n至多提升至15级。","descriptionBuff":null,"extraData":{"addTalentExtraLevel":{"talentType":"AvatarSkill","talentIndex":9,"extraLevel":3}},"icon":"UI_Talent_U_Collei_01"},"5":{"id":5,"talentId":676,"name":"坠镞为林","description":"<color=#FFD780FF>飞叶轮</color>命中时，会产生一个迷你柯里安巴，造成相当于柯莱攻击力200%的<color=#99FF88FF>草元素伤害</color>。\\n每次施放<color=#FFD780FF>拂花偈叶</color>至多产生1次迷你柯里安巴。","descriptionBuff":null,"extraData":null,"icon":"UI_Talent_S_Collei_04","advancedProps":[{"name":"Miniature Cuilein-Anbar","elementalGaugeTheory":"1U","internalCooldown":null,"interruptionResistance":"30","interruptionResistanceStagger":{"staggerLevel":"Light","horizontalForce":"200","verticalForce":"0"},"bluntAttack":false}]}},"dictionary":null}